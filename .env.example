# Deezer Eclipse Addon - Configuration

# Deezer ARL (required)
# To get your ARL:
# 1. Open https://www.deezer.com in your browser
# 2. Login to your Deezer account
# 3. Press F12 to open Developer Tools
# 4. Go to Application tab (Chrome) or Storage tab (Firefox)
# 5. In Cookies section, find 'arl' cookie
# 6. Copy its value and paste it below
# Note: ARL is valid for ~6 months
DEEZER_ARL=your_arl_token_here

# API Key (optional - for securing endpoints)
API_KEY=your_secure_api_key

# Timezone (optional - default: Europe/Paris)
TZ=Europe/Paris

# Log Levels (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# APP_LOG_LEVEL: application logs (search results, streaming, errors)
# GUNICORN_LOG_LEVEL: HTTP server logs (access logs, worker management)
APP_LOG_LEVEL=INFO
GUNICORN_LOG_LEVEL=WARNING