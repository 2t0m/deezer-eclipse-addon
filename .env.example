# Deezer Account Credentials (for automatic ARL refresh)
# If ARL expires, the addon will automatically retrieve a new one
DEEZER_EMAIL=your_email@example.com
DEEZER_PASSWORD=your_password_here

# Security - API Key for addon access
# Generate a strong random key: openssl rand -hex 32
API_KEY=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# Debug mode (true = verbose logs, false = minimal logs)
DEBUG=false